# PostgreSQL connection string (Supabase, Neon, or local)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Groq API key for AI incident classification — get from console.groq.com
GROQ_API_KEY=gsk_...

# Secret key for write endpoint authentication — set something strong in production
API_KEY=change-me-in-production

# Comma-separated list of allowed frontend origins
# Example for Vercel: ["https://your-app.vercel.app","http://localhost:3000"]
CORS_ORIGINS=["http://localhost:3000"]

# How often the world simulation ticks (seconds) — default 30
SIMULATION_TICK_SECONDS=30
